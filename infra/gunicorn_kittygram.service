[Unit]
Description=gunicorn daemon for Kittygram
After=network.target

[Service]
User=_ghbvff
Group=www-data
WorkingDirectory=/home/_ghbvff/kittygram/backend/
Environment="PATH=/home/_ghbvff/kittygram/backend/venv/bin"
ExecStart=/home/_ghbvff/kittygram/backend/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8080 kittygram_backend.wsgi:application

[Install]
WantedBy=multi-user.target
